# Пример файла переменных окружения Pulse Backend
# Скопируйте в .env и заполните реальными значениями:
#   cp .env.example .env

# ── Приложение ──
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32

# ── База данных ──
DATABASE_URL=sqlite+aiosqlite:///./pulse.db

# ── МойСклад API ──
MOYSKLAD_TOKEN=your_moysklad_bearer_token_here

# ── CORS (фронтенд) ──
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── JWT ──
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Синхронизация ──
SYNC_INTERVAL_MINUTES=15
STOCK_SNAPSHOT_CRON=59 23 * * *
